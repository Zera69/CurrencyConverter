<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F5E6D3"  <!-- color pergamino -->
    tools:context=".MainActivity">

        <!-- Título épico -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Conversor de Reinos"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#4A2C1A"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        android:fontFamily="serif"
        android:shadowColor="#8B7355"
        android:shadowRadius="2"
        android:shadowDx="2"
        android:shadowDy="2"/>

        <!-- Sección: Moneda de Origen -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="De:"
        android:textSize="18sp"
        android:textColor="#4A2C1A"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

        <!-- Cantidad a convertir -->
    <EditText
        android:id="@+id/editCantidadOrigen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="0"
        android:inputType="numberDecimal"
        android:background="@android:drawable/editbox_background"
        android:padding="16dp"
        android:textSize="18sp"
        android:layout_marginBottom="16dp"/>

        <!-- Spinner (selector) de moneda origen -->
    <Spinner
        android:id="@+id/spinnerOrigen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:drawable/spinner_background"
        android:padding="12dp"
        android:layout_marginBottom="24dp"/>

        <!-- Divisor decorativo -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#8B7355"
        android:layout_marginVertical="16dp"/>

        <!-- Sección: Moneda de Destino -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="A:"
        android:textSize="18sp"
        android:textColor="#4A2C1A"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

        <!-- Spinner de moneda destino -->
    <Spinner
        android:id="@+id/spinnerDestino"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:drawable/spinner_background"
        android:padding="12dp"
        android:layout_marginBottom="24dp"/>

        <!-- Botón mágico de conversión -->
    <Button
        android:id="@+id/btnConvertir"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="¡Convertir!"
        android:textSize="20sp"
        android:textStyle="bold"
        android:backgroundTint="#8B4513"  <!-- Color marrón/cuero -->
            android:textColor="#F5E6D3"
            android:padding="16dp"
            android:layout_marginVertical="24dp"/>

        <!-- Resultado (con estilo pergamino) -->
    <TextView
        android:id="@+id/textResultado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Resultado:"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#4A2C1A"
        android:gravity="center"
        android:padding="24dp"
        android:background="@android:drawable/editbox_background"
        android:layout_marginTop="16dp"
        android:minHeight="80dp"/>

        <!-- Nota de ambientación (opcional) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Que los dioses de la conversión te sean favorables"
        android:textSize="12sp"
        android:textColor="#8B7355"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:fontFamily="sans-serif-light"
        android:italic="true"/>

    </LinearLayout>